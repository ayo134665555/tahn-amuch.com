  showNotification('Processing checkout...', 'info');
  
  setTimeout(() => {
    showNotification(`Successfully purchased ${AppState.cart.length} apps!`, 'success');
    clearCart();
    closeAllModals();
  }, 1500);
}

// Modal handlers
function closeAllModals() {
  const modals = document.querySelectorAll('.modal');
  modals.forEach(modal => modal.style.display = 'none');
}

// ==========================================
// 10. EVENT DELEGATION
// ==========================================

function setupEventListeners() {
  // Global click handler
  document.addEventListener('click', (e) => {
    const target = e.target;
    const action = target.dataset.action;
    
    // Handle actions
    switch (action) {
      case 'add-to-cart':
        addToCart(parseInt(target.dataset.appId));
        break;
      case 'remove-from-cart':
        removeFromCart(parseInt(target.dataset.appId));
        break;
      case 'toggle-favorite':
        toggleFavorite(parseInt(target.dataset.appId));
        break;
      case 'view-details':
        renderAppDetailsModal(parseInt(target.dataset.appId));
        break;
      case 'clear-cart':
        if (confirm('Clear all items from cart?')) clearCart();
        break;
      case 'checkout':
        handleCheckout();
        break;
      case 'close-modal':
        closeAllModals();
        break;
    }
    
    // Category buttons
    if (target.closest('.category-card')) {
      const category = target.closest('.category-card').dataset.category;
      handleCategoryChange(category);
    }
    
    // Favorite buttons
    if (target.closest('.favorite-btn')) {
      const appId = parseInt(target.closest('.favorite-btn').dataset.appId);
      toggleFavorite(appId);
    }
    
    // Pagination buttons
    if (target.closest('.page-btn') && !target.disabled) {
      const page = parseInt(target.closest('.page-btn').dataset.page);
      if (!isNaN(page)) handlePageChange(page);
    }
    
    // Cart button
    if (target.closest('#cart-btn')) {
      renderCartModal();
    }
    
    // Favorites button
    if (target.closest('#favorites-btn')) {
      showNotification('Favorites view coming soon!', 'info');
    }
    
    // Close modal on outside click
    if (target.classList.contains('modal')) {
      closeAllModals();
    }
  });
  
  // Search input
  document.addEventListener('input', (e) => {
    if (e.target.id === 'search-input') {
      handleSearch(e.target.value);
    }
  });
  
  // Sort select
  document.addEventListener('change', (e) => {
    if (e.target.id === 'sort-select') {
      handleSortChange(e.target.value);
    }
  });
  
  // Keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    // ESC to close modals
    if (e.key === 'Escape') {
      closeAllModals();
    }
    
    // Ctrl/Cmd + K for search
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      document.getElementById('search-input')?.focus();
    }
  });
}

// ==========================================
// 11. INITIALIZATION
// ==========================================

function initializeApp() {
  console.log('🚀 Initializing JIT Marketplace...');
  
  // Initialize data
  initializeData();
  
  // Render initial UI
  renderNavigation();
  renderCategories();
  renderSortOptions();
  renderApps();
  
  // Setup event listeners
  setupEventListeners();
  
  console.log('✅ App initialized successfully!');
  showNotification('Welcome to JIT Marketplace!', 'success');
}

// ==========================================
// 12. APP ENTRY POINT
// ==========================================

// Wait for DOM to be ready
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initializeApp);
} else {
  initializeApp();
}

// Export for testing (if needed)
if (typeof module !== 'undefined' && module.exports) {
  module.exports = {
    AppState,
    initializeData,
    getFilteredApps,
    addToCart,
    removeFromCart,
    toggleFavorite,
    formatPrice,
    formatNumber
  };
}
