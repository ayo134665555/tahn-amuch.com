function addToCart(appId) {
  const app = AppState.apps.find(a => a.id === appId);
  if (!app) return;
  
  // Check if already in cart
  if (AppState.cart.find(item => item.id === appId)) {
    showNotification('App already in cart', 'info');
    return;
  }
  
  AppState.cart.push({ ...app, addedAt: Date.now() });
  Storage.save('cart', AppState.cart);
  
  updateCartUI();
  showNotification(`${app.name} added to cart`, 'success');
}

function removeFromCart(appId) {
  const index = AppState.cart.findIndex(item => item.id === appId);
  if (index === -1) return;
  
  const app = AppState.cart[index];
  AppState.cart.splice(index, 1);
  Storage.save('cart', AppState.cart);
  
  updateCartUI();
  showNotification(`${app.name} removed from cart`, 'info');
}

function clearCart() {
  AppState.cart = [];
  Storage.save('cart', []);
  updateCartUI();
  showNotification('Cart cleared', 'info');
}

function getCartTotal() {
  return AppState.cart.reduce((total, item) => total + item.price, 0);
}

